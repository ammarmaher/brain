{
  "brainName": "Brain SK v0.1",
  "brainRepo": "https://github.com/ammarmaher/brain",
  "projectRoot": "C:/Falcon/Falcon",
  "defaultBranch": "main",
  "autoSyncBrainArtifacts": true,
  "autoPushImplementationAfterQualityGates": true,
  "discovery": {
    "autoDiscoverFromProjectRoot": true,
    "generateUnderstandingOutputs": true,
    "frontend": {
      "enabled": true,
      "path": null,
      "detectBy": [
        "angular.json",
        "nx.json",
        "package.json",
        "apps",
        "libs",
        "project.json",
        "tailwind.config"
      ]
    },
    "backend": {
      "enabled": true,
      "path": null,
      "detectBy": [
        "*.sln",
        "*.csproj",
        "Controllers",
        "Program.cs",
        "appsettings.json",
        "Validators",
        "Dtos",
        "DTOs",
        "Services",
        "Entities"
      ]
    },
    "gateway": {
      "enabled": true,
      "path": null,
      "detectBy": [
        "ocelot.json",
        "gateway",
        "Gateway",
        "ApiGateway",
        "YARP"
      ]
    },
    "prd": {
      "enabled": true,
      "path": null,
      "detectBy": [
        "prd",
        "PRD",
        "requirements",
        "epics",
        "stories",
        "business"
      ]
    },
    "wiki": {
      "enabled": true,
      "path": null,
      "detectBy": [
        "wiki",
        "docs",
        "architecture",
        "diagrams",
        "images",
        "standards"
      ]
    }
  },
  "obsidian": {
    "enabled": true,
    "autoLink": true,
    "vaultPath": "C:/Falcon/Brain SK/_obsidian",
    "linkGeneratedOutputRoot": "C:/Falcon/Brain Outputs",
    "generateIndexNotes": true,
    "continueIfMissing": true
  },
  "outputs": {
    "writeGeneratedUnderstandingOutsideBrainCore": true,
    "root": "C:/Falcon/Brain Outputs",
    "discovery": "C:/Falcon/Brain Outputs/discovery",
    "understanding": "C:/Falcon/Brain Outputs/understanding",
    "bootstrap": "C:/Falcon/Brain Outputs/bootstrap",
    "businessUnderstanding": "C:/Falcon/Brain Outputs/business-understanding",
    "backendUnderstanding": "C:/Falcon/Brain Outputs/backend-understanding",
    "frontendUnderstanding": "C:/Falcon/Brain Outputs/understanding/frontend",
    "frontendComponents": "C:/Falcon/Brain Outputs/understanding/frontend/components",
    "componentRegistry": "C:/Falcon/Brain Outputs/understanding/frontend",
    "reports": "C:/Falcon/Brain Outputs/reports",
    "scanMetadata": "C:/Falcon/Brain Outputs/scan-metadata",
    "obsidianLinkedNotes": "C:/Falcon/Brain Outputs/obsidian-linked-notes",
    "obsidianIndex": "C:/Falcon/Brain SK/_obsidian",
    "legacy": {
      "_comment": "These paths are LEGACY / IMPORT / MIRROR only. Do NOT use as active source. Canonical frontend knowledge lives at outputs.frontendUnderstanding and outputs.frontendComponents above.",
      "componentRegistry": "C:/Falcon/Brain Outputs/component-registry",
      "frontendUnderstanding": "C:/Falcon/Brain Outputs/frontend-understanding",
      "componentRegistryMirror": "C:/Falcon/Brain SK/outputs/component-registry",
      "frontendUnderstandingMirror": "C:/Falcon/Brain SK/outputs/frontend-understanding"
    }
  },
  "authorization": {
    "askOnlyWhenRequired": true,
    "useEnvironmentVariablesFirst": true,
    "localSecretsFile": "config/local.secrets.json",
    "neverCommitSecrets": true
  },
  "scan": {
    "excludeActiveScanFolders": [
      "legacy",
      "legacy-v7",
      "archived",
      "old",
      "backup",
      "generated-archive",
      "previous-brain",
      "node_modules",
      "dist",
      "bin",
      "obj",
      ".vs",
      ".git"
    ]
  },
  "falconWorkspaceRoot": "C:/Falcon",
  "brainCorePath": "C:/Falcon/Brain SK",
  "generatedOutputRoot": "C:/Falcon/Brain Outputs",
  "paths": {
    "falconWorkspaceRoot": "C:/Falcon",
    "brainCorePath": "C:/Falcon/Brain SK",
    "projectRoot": "C:/Falcon/Falcon",
    "generatedOutputRoot": "C:/Falcon/Brain Outputs",
    "obsidianVaultPath": "C:/Falcon/Brain SK/_obsidian",
    "prdDriveUrl": "https://drive.google.com/drive/folders/1ww3nICya-CjW4_5mzoVpzTaaMz9nNTtH",
    "prdLocalMirror": "C:/Falcon/Brain SK/skills/imported-business/prd-knowledge/modules",
    "prdGeneratedOutputRoot": "C:/Falcon/Brain Outputs/prd",
    "architectureWikiUrl": "https://t2development.visualstudio.com/Falcon/_wiki/wikis/Falcon.wiki/1129/Home",
    "architectureWikiGitUrl": "https://t2development.visualstudio.com/Falcon/_git/Falcon.wiki",
    "architectureWikiGitBranch": "wikiMaster",
    "architectureWikiLocalClone": "C:/Falcon/falcon-wiki",
    "architectureWikiGeneratedOutputRoot": "C:/Falcon/Brain Outputs/wiki-architect"
  },
  "incrementalScan": {
    "_comment": "Configuration for domains/frontend/component-knowledge/incremental-scan/SKILL.md",
    "enabled": true,
    "engineScript": "C:/Falcon/Brain SK/scripts/incremental-scan/run-scan.mjs",
    "activeFrontendSource": "C:/Falcon/Falcon/falcon-web-platform-ui",
    "knowledgeRoot": "C:/Falcon/Brain Outputs/understanding/frontend",
    "componentsDir": "C:/Falcon/Brain Outputs/understanding/frontend/components",
    "scanStateDir": "C:/Falcon/Brain Outputs/understanding/frontend/_scan-state",
    "scanMetadataFile": "C:/Falcon/Brain Outputs/understanding/frontend/_scan-state/component-scan-metadata.json",
    "scanRunLog": "C:/Falcon/Brain Outputs/understanding/frontend/_scan-state/FRONTEND_COMPONENT_SCAN_RUN.md",
    "reportsRoot": "C:/Falcon/Brain Outputs/reports/component-scans",
    "reportFolderPattern": "<YYYY-MM-DD-HHmm>",
    "requiredKnowledgeFiles": ["OVERVIEW.md","API.md","USAGE.md","TOKENS.md","GAPS_AND_UPGRADES.md","DECISION.md"],
    "timestampFormat": "ISO-8601 with offset (e.g. 2026-05-13T22:45:00+03:00)",
    "editTracking": {
      "method": "git",
      "authorFormat": "%an <%ae>",
      "dateFormat": "%aI",
      "commitFormat": "%H",
      "fallbackForUntracked": "UNKNOWN_NOT_IN_GIT",
      "untrackedDateSource": "filesystem-mtime"
    },
    "pdf": {
      "preferredSkill": "pdf-creator",
      "fallback": "npx-md-to-pdf",
      "themeCss": "C:/Falcon/reports/Falcon Component Reports Understanding/_pdf-theme.css",
      "configJs": "C:/Falcon/reports/Falcon Component Reports Understanding/_pdf-config.js",
      "pendingMarkerSuffix": ".pdf.pending"
    },
    "obsidianLinks": {
      "updateFrontendIndex": true,
      "updateFalconComponentIndex": true,
      "neverTouchPluginData": true
    },
    "gitSync": {
      "addSpecificPathsOnly": true,
      "preCommitSecretGrep": true,
      "commitMessageTemplate": "feat(frontend): incremental component scan <RUN_STAMP>"
    },
    "scanReportFieldsRequired": ["lastEditedBy","lastEditedAt","changedFilesSinceLastScan","status","scanReason","skipReason"]
  },
  "gitSync": {
    "enabled": true,
    "brainRepoPath": "C:/Falcon/Brain SK",
    "brainRepoUrl": "https://github.com/ammarmaher/brain",
    "syncGeneratedOutputsToBrainRepo": true,
    "generatedOutputRoot": "C:/Falcon/Brain Outputs",
    "generatedOutputRepoMirror": "C:/Falcon/Brain SK/outputs",
    "autoCommit": true,
    "autoPush": true,
    "exclude": [
      "**/.env",
      "**/*.key",
      "**/*.pem",
      "**/*secret*",
      "**/*password*",
      "**/node_modules/**",
      "**/dist/**",
      "**/bin/**",
      "**/obj/**",
      "**/.git/**"
    ]
  }
}