# Local secrets and machine-specific config
config/local.secrets.json
*.secrets.json
.env
.env.*
**/.env
*.pem
**/*.pem
*.key
**/*.key
*.pfx
*.p12

# Build/temp
node_modules/
dist/
bin/
obj/
.vs/
.tmp/
temp/

# vault-search ONNX model cache (downloaded on first run, ~33MB)
scripts/vault-search/model-cache/

# Logs
*.log

# Secondary local Obsidian staging vault (contains plugin data with API keys).
# Canonical Brain SK vault is `_obsidian/`, which IS tracked.
Obsidian Vault/

# Any Obsidian plugin / workspace state (plugin auth tokens / API keys live here).
**/.obsidian/plugins/*/data.json
**/.obsidian/plugins/*/main.js
**/.obsidian/plugins/*/main.js.map
**/.obsidian/plugins/*/styles.css
**/.obsidian/plugins/*/manifest.json
**/.obsidian/plugins/*/.env
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/cache/**

# Obsidian Smart Connections / Smart Lookup vector cache (large, machine-specific)
**/.smart-env/
**/.smart-connections/

# Generic credential filename guards. Negations below keep templates,
# example files, and Markdown documentation committable.
**/*secret*
**/*password*
**/*token*

# --- Negations: legitimate files that must remain trackable ---
# Keep all Markdown documentation (e.g. OBSIDIAN_SECRET_HANDLING.md, knowledge notes).
!**/*.md
# Keep clearly-marked example/template files (no real values inside).
!**/*.example.*
!**/*.template.*
!**/*.sample.*
