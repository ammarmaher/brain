{
  "$schema": "./falcon-eyes.schema.json",
  "source": {
    "url": "http://localhost:3000/T2%20Falcon%20Admin",
    "label": "T2 Falcon Admin (reference)"
  },
  "destination": {
    "url": "http://localhost:4200/admin-console/org-hierarchy-page?visual-test=1",
    "label": "Falcon Angular admin-console/org-hierarchy-page (visual-test bypass)"
  },
  "viewport": {
    "width": 1440,
    "height": 900,
    "deviceScaleFactor": 1
  },
  "wait": {
    "state": "networkidle",
    "extraDelayMs": 4500
  },
  "pixelmatch": {
    "threshold": 0.1,
    "includeAA": false,
    "diffColor": [255, 0, 255]
  },
  "output": {
    "rootDir": "C:\\Falcon\\Brain Outputs\\reports\\falcon-eyes",
    "mirrorTo": "C:\\Falcon\\Brain SK\\outputs\\reports\\falcon-eyes",
    "writeFullPage": true,
    "writeSectionScreenshots": true,
    "writeDiffImages": true,
    "writeJson": true,
    "writeMarkdown": true
  },
  "navigation": {
    "preWaitForSelector": "app-org-hierarchy-page-menu",
    "scrollToTopBeforeCapture": true
  },
  "headless": true
}
