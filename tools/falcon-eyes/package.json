{
  "name": "falcon-eyes",
  "version": "0.1.0",
  "private": true,
  "description": "Falcon Eyes — semantic visual difference QA tool for Brain SK. Captures source/destination screenshots, runs pixelmatch, and writes report templates that Claude fills in semantically.",
  "type": "module",
  "scripts": {
    "capture": "tsx capture-and-compare.ts",
    "compare": "tsx compare-images.ts",
    "install-browsers": "playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.49.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
